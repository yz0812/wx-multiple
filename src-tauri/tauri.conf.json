{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "微信多开",
  "version": "0.1.0",
  "identifier": "com.local.weixin-multi-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "微信多开",
        "width": 500,
        "height": 440,
        "center": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
